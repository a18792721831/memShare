# ============================================================
# memShare Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Storage Backend: "local" or "cos" or "s3"
MEMSHARE_STORAGE=local

# Local storage path (default: ~/memshare-data)
MEMSHARE_DATA_DIR=~/memshare-data

# --- Tencent Cloud COS (if MEMSHARE_STORAGE=cos) ---
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-bucket-name-1250000000
COS_REGION=ap-guangzhou

# --- AWS S3 (if MEMSHARE_STORAGE=s3) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# --- Sync Settings ---
# Sync interval in seconds (for crontab, set to 0 to disable)
SYNC_INTERVAL=60

# --- Agent Identity ---
# Name of this AI agent (used in mailbox and daily-memories)
AGENT_NAME=my-agent
