# memShare - Tencent Cloud COS Configuration
# Copy this file to your memShare data directory as .env

# Data directory
MEMSHARE_DATA_DIR=~/memshare-data

# Agent identity
AGENT_NAME=my-agent

# Storage backend
MEMSHARE_STORAGE=cos

# Tencent Cloud COS credentials
COS_SECRET_ID=your-secret-id-here
COS_SECRET_KEY=your-secret-key-here
COS_BUCKET=your-bucket-name-1234567890
COS_REGION=ap-guangzhou
