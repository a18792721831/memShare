{
  "_comment": "Example MCP configuration for memShare. Copy the relevant section to your AI tool's config.",

  "claude-desktop": {
    "mcpServers": {
      "memshare": {
        "command": "python3",
        "args": ["/path/to/memShare/mcp_server.py"],
        "env": {
          "MEMSHARE_DATA_DIR": "~/memshare-data",
          "AGENT_NAME": "claude"
        }
      }
    }
  },

